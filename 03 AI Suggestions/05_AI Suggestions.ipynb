     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "gemini_api_key = \"put your api here"\n",
    "client_ai = genai.Client(api_key=gemini_api_key)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "a50c2808-c9f0-49ce-8b04-be6e0d149c42",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### Find months that need an AI recommendation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "fa41dafa-cd0e-4c0c-9785-2017b718e3b8",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "shortages_query = \"\"\"\n",
    "SELECT\n",
    "    month_key,\n",
    "    shortage_flag,\n",
    "    monthly_income,\n",
    "    monthly_expenses,\n",
    "    net_cash_flow,\n",
    "    closing_balance,\n",
    "    avg_3m_income,\n",
    "    avg_3m_expenses,\n",
    "    income_vs_avg_pct,\n",
    "    expense_vs_avg_pct,\n",
    "    flag_explanation\n",
    "FROM cash_flow_project.cash_flow_gold.vw_shortage_detection\n",
    "WHERE needs_ai_suggestion = true\n",
    "ORDER BY month_key DESC\n",
    "\"\"\"\n",
    "\n",
    "shortages_df = spark.sql(shortages_query).toPandas()\n",
    "\n",
    "if shortages_df.empty:\n",
    "    print(\"All financial indicators are healthy. No AI suggestions needed.\")\n",
    "else:\n",
    "    print(f\"Found {len(shortages_df)} month(s) requiring AI analysis.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "a797d731-615a-43da-bf28-84db2f529a6d",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### Generate one structured recommendation per flagged month\n",
    "Collects every Gold view for context, then asks Gemini to return the\n",
    "result as JSON matching a fixed schema (so it can be stored in a table\n",
    "with real columns instead of free text)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "d976d474-208f-4fdb-84bd-0ff6a4a8f870",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "results = []\n",
    "\n",
    "for _, row in shortages_df.iterrows():\n",
    "\n",
    "    month = row[\"month_key\"]\n",
    "    print(f\"Analyzing {month}\")\n",
    "\n",
    "    # Pull every relevant Gold view for this one month, as plain text tables\n",
    "    kpi_df = spark.sql(f\"\"\"\n",
    "    SELECT * FROM cash_flow_project.cash_flow_gold.vw_business_kpi_summary\n",
    "    WHERE month_key = '{month}'\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    overview_df = spark.sql(f\"\"\"\n",
    "    SELECT * FROM cash_flow_project.cash_flow_gold.vw_monthly_financial_overview\n",
    "    WHERE month_key = '{month}'\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    expense_df = spark.sql(f\"\"\"\n",
    "    SELECT * FROM cash_flow_project.cash_flow_gold.vw_expense_breakdown\n",
    "    WHERE month_key = '{month}'\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    runway_df = spark.sql(f\"\"\"\n",
    "    SELECT * FROM cash_flow_project.cash_flow_gold.vw_cash_runway\n",
    "    WHERE month_key = '{month}'\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    vendors_df = spark.sql(f\"\"\"\n",
    "    SELECT vendor, category_name, total_spend, num_transactions\n",
    "    FROM cash_flow_project.cash_flow_gold.vw_credit_card_vendor_spend\n",
    "    WHERE month_key = '{month}'\n",
    "    ORDER BY total_spend DESC LIMIT 3\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    products_df = spark.sql(f\"\"\"\n",
    "    SELECT product_category, product_type, total_revenue, total_units_sold, avg_unit_price, time_of_day\n",
    "    FROM cash_flow_project.cash_flow_gold.vw_sales_product_performance\n",
    "    WHERE month_key = '{month}'\n",
    "    ORDER BY total_revenue DESC LIMIT 5\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    payroll_df = spark.sql(f\"\"\"\n",
    "    SELECT employee_name, role, pay_type, total_paid, pct_of_monthly_revenue\n",
    "    FROM cash_flow_project.cash_flow_gold.vw_payroll_analysis\n",
    "    WHERE month_key = '{month}'\n",
    "    ORDER BY total_paid DESC LIMIT 5\n",
    "    \"\"\").toPandas()\n",
    "\n",
    "    # Turn each dataframe into plain text for the prompt (or a fallback note if empty)\n",
    "    kpi_text = kpi_df.to_string(index=False) if not kpi_df.empty else \"No KPI data available.\"\n",
    "    overview_text = overview_df.to_string(index=False) if not overview_df.empty else \"No monthly overview available.\"\n",
    "    expense_text = expense_df.to_string(index=False) if not expense_df.empty else \"No expense breakdown available.\"\n",
    "    runway_text = runway_df.to_string(index=False) if not runway_df.empty else \"No runway information available.\"\n",
    "    vendors_text = vendors_df.to_string(index=False) if not vendors_df.empty else \"No vendor spending available.\"\n",
    "    products_text = products_df.to_string(index=False) if not products_df.empty else \"No product performance available.\"\n",
    "    payroll_text = payroll_df.to_string(index=False) if not payroll_df.empty else \"No payroll information available.\"\n",
    "\n",
    "    financial_context = f\"\"\"\n",
    "Month: {row['month_key']}\n",
    "Detected Issue: {row['flag_explanation']}\n",
    "Shortage Flag: {row['shortage_flag']}\n",
    "Revenue: {row['monthly_income']}\n",
    "Expenses: {row['monthly_expenses']}\n",
    "Net Cash Flow: {row['net_cash_flow']}\n",
    "Closing Balance: {row['closing_balance']}\n",
    "Average Revenue (Last 3 Months): {row['avg_3m_income']}\n",
    "Average Expenses (Last 3 Months): {row['avg_3m_expenses']}\n",
    "Revenue vs Average: {row['income_vs_avg_pct']} %\n",
    "Expense vs Average: {row['expense_vs_avg_pct']} %\n",
    "\"\"\"\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "You are a senior Chief Financial Officer (CFO) and business consultant specializing in coffee shop businesses.\n",
    "Your job is NOT only to give advice.\n",
    "First, analyze the available business data.\n",
    "Second, identify the REAL root cause of the financial issue.\n",
    "Third, recommend practical actions supported by the data.\n",
    "Use ALL the information below before making any recommendation.\n",
    "\n",
    "IMPORTANT DATA NOTE: the KPI summary below may show two different revenue\n",
    "figures - \"revenue\" (net bank deposits) and \"pos_gross_revenue\" (gross POS\n",
    "sales). pos_gross_revenue is expected to be roughly 2.9x larger than revenue\n",
    "because it is measured before payment-processor fees are deducted. This is\n",
    "a known, documented characteristic of the data, not a discrepancy or error -\n",
    "do not flag it as an issue or root cause.\n",
    "\n",
    "PRIMARY FINANCIAL CONTEXT\n",
    "{financial_context}\n",
    "\n",
    "EXECUTIVE KPI SUMMARY\n",
    "{kpi_text}\n",
    "\n",
    "MONTHLY FINANCIAL OVERVIEW\n",
    "{overview_text}\n",
    "\n",
    "EXPENSE BREAKDOWN\n",
    "{expense_text}\n",
    "\n",
    "CASH RUNWAY\n",
    "{runway_text}\n",
    "\n",
    "TOP CREDIT CARD VENDORS\n",
    "{vendors_text}\n",
    "\n",
    "TOP SELLING PRODUCTS\n",
    "{products_text}\n",
    "\n",
    "PAYROLL ANALYSIS\n",
    "{payroll_text}\n",
    "\n",
    "Instructions\n",
    "Use the provided data only.\n",
    "Avoid generic financial advice.\n",
    "Explain WHY the issue happened.\n",
    "Mention important trends.\n",
    "Reference the biggest expense drivers if applicable.\n",
    "Reference sales performance if applicable.\n",
    "Reference payroll if applicable.\n",
    "Reference vendor spending if applicable.\n",
    "Prioritize recommendations by business impact.\n",
    "Return ONLY valid JSON.\n",
    "\n",
    "Use this exact schema:\n",
    "{{\n",
    "    \"month\":\"\",\n",
    "    \"issue\":\"\",\n",
    "    \"root_cause\":\"\",\n",
    "    \"priority\":\"Low | Medium | High | Critical\",\n",
    "    \"business_impact\":\"\",\n",
    "    \"recommendations\":[\n",
    "        \"...\",\n",
    "        \"...\",\n",
    "        \"...\"\n",
    "    ]\n",
    "}}\n",
    "\"\"\"\n",
    "\n",
    "    result = client_ai.models.generate_content(\n",
    "        model='gemini-3.1-flash-lite',\n",
    "        contents=prompt,\n",
    "        config=types.GenerateContentConfig(\n",
    "            response_mime_type=\"application/json\"\n",
    "        )\n",
    "    )\n",
    "\n",
    "    output_json = json.loads(result.text)\n",
    "    print(json.dumps(output_json, indent=4))\n",
    "\n",
    "    # Keep this month's parsed result, plus a timestamp, for the table write below\n",
    "    results.append({\n",
    "        \"month_key\": output_json.get(\"month\", month),\n",
    "        \"issue\": output_json.get(\"issue\", \"\"),\n",
    "        \"root_cause\": output_json.get(\"root_cause\", \"\"),\n",
    "        \"priority\": output_json.get(\"priority\", \"Low\"),\n",
    "        \"business_impact\": output_json.get(\"business_impact\", \"\"),\n",
    "        \"recommendations_json\": json.dumps(output_json.get(\"recommendations\", [])),\n",
    "        \"generated_at\": datetime.utcnow().isoformat(),\n",
    "    })"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "dc195928-e817-4c40-b700-03871d9972f4",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### Save results to a Delta table\n",
    "This is what the website reads from — one row per flagged month, with\n",
    "`recommendations_json` holding the list of suggestion strings as a JSON\n",
    "array (kept as a string column so any SQL client, including the\n",
    "databricks-sql-connector the Flask app uses, can read it without special\n",
    "array-type handling — the app just does `json.loads()` on it).\n",
    "\n",
    "Full overwrite each run: this table always reflects \"every month that\n",
    "currently needs a suggestion,\" recomputed from scratch, which matches\n",
    "how `shortages_df` itself is built above (always the current full list)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "77a7efbb-4016-40d6-a681-7d96cee37465",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "schema = StructType([\n",
    "    StructField(\"month_key\", StringType(), True),\n",
    "    StructField(\"issue\", StringType(), True),\n",
    "    StructField(\"root_cause\", StringType(), True),\n",
    "    StructField(\"priority\", StringType(), True),\n",
    "    StructField(\"business_impact\", StringType(), True),\n",
    "    StructField(\"recommendations_json\", StringType(), True),\n",
    "    StructField(\"generated_at\", StringType(), True),\n",
    "])\n",
    "results_df = spark.createDataFrame(results, schema=schema) if results else spark.createDataFrame([], schema=schema)\n",
    "\n",
    "(results_df.write.format(\"delta\").mode(\"overwrite\")\n",
    " .option(\"overwriteSchema\", \"true\")\n",
    " .saveAsTable(\"cash_flow_project.cash_flow_gold.ai_suggestions\"))\n",
    "\n",
    "print(f\"Saved {results_df.count()} AI suggestion(s) to cash_flow_gold.ai_suggestions\")"
   ]
  },

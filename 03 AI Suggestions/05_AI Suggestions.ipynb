   "source": [
    "from google import genai\n",
    "from google.genai import types\n",
    "import pandas as pd\n",
    "import json\n",
    "from datetime import datetime\n",
    "from pyspark.sql import functions as F\n",
    "from pyspark.sql.types import StructType, StructField, StringType, TimestampType, ArrayType"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "c8bb3820-5afe-4270-9de6-a313ac36c852",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### API key setup (one-time, do this before running the cell below)\n",
    "Run this once via the Databricks CLI to store the key as a secret instead\n",
    "of plain text:\n",
    "```\n",
    "databricks secrets create-scope ai-suggestions-secrets\n",
    "databricks secrets put-secret ai-suggestions-secrets gemini-api-key --string-value \"YOUR_NEW_ROTATED_KEY\"\n",
    "```\n",
    "Then the notebook reads it with `dbutils.secrets.get(...)` below — nothing\n",
    "sensitive stays in the notebook file itself."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
